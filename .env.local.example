# ============================================================
# Still Photo Team Calendar — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================


# ─── Supabase ────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key — server-side only, NEVER expose to client
# Used for: admin delete user, read all profiles in notify/cron routes
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ─── Web Push (VAPID) ────────────────────────────────────────
# Generate a fresh key pair by running:
#   npx web-push generate-vapid-keys
#
# NEXT_PUBLIC_ prefix = safe to expose to browser (public key only!)
# VAPID_PRIVATE_KEY   = server-side only

NEXT_PUBLIC_VAPID_PUBLIC_KEY=BB4KOYN0spDYecXQIfltzO7T96XL-2KMwlGDzxy7e_JOtI7uGrj_qjBKARAdnh66CUGuSsy-45Z5337umJAgSqc
VAPID_PRIVATE_KEY=f5irZ196mqsDHS6ypcS6Yrl-JV-XBuu_z0Arx2H9d9s
VAPID_EMAIL=mailto:admin@example.com


# ─── Telegram Bot ────────────────────────────────────────────
# 1. Chat with @BotFather on Telegram → /newbot → copy token
# 2. Add the bot to your group, send a message, then run:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find the group's chat_id (negative number for groups)
# 3. Each member fills their personal Chat ID in their Profile page
#    via: https://t.me/userinfobot

TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Group chat ID (optional) — bot will also notify the whole group
# For groups this is usually a negative number, e.g. -1001234567890
TELEGRAM_CHAT_ID=-1001234567890


# ─── Email (SMTP via Gmail) ───────────────────────────────────
# Gmail setup (free):
# 1. Enable 2-Step Verification on your Google account
# 2. Go to: myaccount.google.com → Security → App Passwords
# 3. Create an App Password for "Mail" → copy the 16-char password
# 4. Use your Gmail address as SMTP_USER and the app password as SMTP_PASS
#
# Alternative SMTP providers: Outlook (smtp-mail.outlook.com:587),
# Zoho (smtp.zoho.com:587), or any SMTP server you have access to.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourteam@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM is optional — defaults to SMTP_USER if not set
SMTP_FROM=yourteam@gmail.com


# ─── Cron Security ───────────────────────────────────────────
# Vercel automatically sends this as "Authorization: Bearer <secret>"
# when calling your cron endpoints. Generate any random string:
#   openssl rand -hex 32
# Set the same value in: Vercel Dashboard → Project → Settings → Environment Variables

CRON_SECRET=your-random-secret-here-change-this


# ─── App URL ─────────────────────────────────────────────────
# Used in email templates for the "Buka Kalender" button link.
# In development: http://localhost:3030
# In production:  https://your-app.vercel.app

NEXT_PUBLIC_APP_URL=http://localhost:3030
